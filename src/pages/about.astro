---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, SOCIALS } from "@/consts";

// Featured open-source work (kept inline; small enough not to need a collection).
const projects = [
  {
    name: "open-vibe-island",
    desc: "为重度 code agent 用户设计的 macOS 工具，open vibe-island 的开源替代品。支持 cc / codex / opencode，terminal / ghostty / cmux / kaku / iterm。",
    lang: "Swift",
    stars: 1358,
    href: "https://github.com/Octane0411/open-vibe-island",
  },
  {
    name: "opencode-plugin-openspec",
    desc: "OpenCode 插件，集成 OpenSpec，新增专用的 openspec-plan 模式用于创建与编辑 spec 文件。",
    lang: "TypeScript",
    stars: 120,
    href: "https://github.com/Octane0411/opencode-plugin-openspec",
  },
];

const focus = [
  "AI coding agents 架构剖析",
  "Claude Code",
  "Codex",
  "OpenCode",
  "开发者工具",
  "macOS 原生体验",
];

const elsewhere = [
  { label: "GitHub", href: SOCIALS.github, handle: "@Octane0411" },
  { label: "RSS", href: "/rss.xml", handle: "全文订阅" },
];

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.author,
  url: SITE.url,
  description: SITE.description,
  sameAs: SOCIALS.sameAs,
  knowsAbout: focus,
};
---

<BaseLayout
  title="About"
  description="关于 Octane — Builder，专注 AI coding agents 架构剖析与开发者工具。代表作 open-vibe-island、opencode-plugin-openspec。"
  jsonLd={personLd}
>
  <div class="mx-auto max-w-[42rem] px-5 py-14 sm:py-20">
    <!-- Intro -->
    <section>
      <p
        class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-accent)]"
      >
        About
      </p>
      <h1
        class="mt-3 font-serif text-3xl font-medium leading-tight tracking-tight sm:text-[2.6rem]"
      >
        嗨，我是 Octane。<br />一名 Builder。
      </h1>
      <p
        class="mt-6 font-serif text-xl leading-relaxed text-[var(--color-muted)] italic"
      >
        日常重度使用 AI coding agents，并以此为方向开源工具、剖析它们的架构与实现。
        这个站点用来沉淀我对 Claude Code、Codex、OpenCode 的深入思考。
      </p>
    </section>

    <!-- Now -->
    <section class="mt-16">
      <h2
        class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-faint)]"
      >
        最近在做
      </h2>
      <p class="mt-4 leading-relaxed text-[var(--color-text)]">
        围绕「重度 code agent 用户的 macOS 原生体验」持续打磨工具，
        同时把工程实践和源码分析写成文章，做长期沉淀与传播。
      </p>
    </section>

    <!-- Selected work -->
    <section class="mt-16">
      <h2
        class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-faint)]"
      >
        精选项目
      </h2>
      <div class="mt-5 space-y-3">
        {
          projects.map((p) => (
            <a
              href={p.href}
              class="group block rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5 transition-colors hover:border-[var(--color-accent)]"
            >
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-serif text-lg font-medium tracking-tight group-hover:text-[var(--color-accent)]">
                  {p.name}
                </h3>
                <span class="shrink-0 text-sm text-[var(--color-faint)]">
                  ★ {p.stars.toLocaleString()}
                </span>
              </div>
              <p class="mt-2 text-[0.95rem] leading-relaxed text-[var(--color-muted)]">
                {p.desc}
              </p>
              <span class="mt-3 inline-block text-xs text-[var(--color-faint)]">
                {p.lang}
              </span>
            </a>
          ))
        }
      </div>
      <a
        href={SOCIALS.github}
        class="mt-5 inline-block text-sm text-[var(--color-muted)] hover:text-[var(--color-text)]"
        >GitHub 上的更多项目 →</a
      >
    </section>

    <!-- Focus areas -->
    <section class="mt-16">
      <h2
        class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-faint)]"
      >
        关注方向
      </h2>
      <div class="mt-4 flex flex-wrap gap-2">
        {
          focus.map((tag) => (
            <span class="rounded-full border border-[var(--color-border)] px-3 py-1 text-sm text-[var(--color-muted)]">
              {tag}
            </span>
          ))
        }
      </div>
    </section>

    <!-- Elsewhere -->
    <section class="mt-16 border-t border-[var(--color-border)] pt-8">
      <h2
        class="text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-faint)]"
      >
        联系
      </h2>
      <ul class="mt-4 space-y-2">
        {
          elsewhere.map((link) => (
            <li class="flex items-baseline gap-3">
              <a
                href={link.href}
                class="text-[var(--color-accent)] underline-offset-4 hover:underline"
              >
                {link.label}
              </a>
              <span class="text-sm text-[var(--color-faint)]">
                {link.handle}
              </span>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</BaseLayout>
